{
  "manifest_version": 2,
  "name": "Oldoogle XP Homepage",
  "description": "Windows XP styled Oldoogle homepage and new tab page.",
  "version": "1.0.0",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "chrome_settings_overrides": {
    "homepage": "index.html"
  },
  "permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "oldoogle-xp-homepage@local"
    }
  }
}
